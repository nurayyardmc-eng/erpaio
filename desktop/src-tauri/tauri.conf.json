{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ERPAIO",
  "version": "1.0.0",
  "identifier": "com.nurayyardmc.erpaio.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ERPAIO",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "https://erpaio.vercel.app",
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "erpaio.vercel.app"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "category": "Business",
    "shortDescription": "ERPAIO — Talk to your ERP in Turkish",
    "longDescription": "Native desktop client for ERPAIO. Query your ERP database in natural Turkish, get anomaly alerts, all from your Mac or Windows."
  }
}
