# =====================================================================
# ERPAIO — Environment Variables
# =====================================================================
# .env.local olarak kopyalayıp gerçek değerlerle doldurun.
# Schema: src/lib/env.ts (Zod ile validate edilir)
# =====================================================================

# ---------------------------------------------------------------------
# DATABASE — Supabase / Postgres (REQUIRED)
# ---------------------------------------------------------------------
# Pooled connection (uygulama runtime'ında)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# Direct connection (Prisma migration için)
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------
# AUTH (REQUIRED)
# ---------------------------------------------------------------------
# JWT secret — `openssl rand -base64 32` ile üretin
NEXTAUTH_SECRET=
# Production URL (otomatik Vercel'den alınabilir)
NEXTAUTH_URL=https://erpaio.vercel.app

# ---------------------------------------------------------------------
# ENCRYPTION (REQUIRED)
# ---------------------------------------------------------------------
# AES-256-GCM key, 64-char hex (32 byte) — `openssl rand -hex 32` ile üretin
# Bu anahtar değişirse tüm ERP credential'ları okunamaz hale gelir
ENCRYPTION_KEY=

# ---------------------------------------------------------------------
# AI — Anthropic Claude (REQUIRED)
# ---------------------------------------------------------------------
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------
# CRON (REQUIRED)
# ---------------------------------------------------------------------
# GitHub Actions cron auth — random string min 16 char
CRON_SECRET=

# ---------------------------------------------------------------------
# EMAIL — Resend (Önerilen)
# ---------------------------------------------------------------------
RESEND_API_KEY=re_...
# Sender adresi — kendi domain DNS doğrulanmadıysa onboarding@resend.dev
RESEND_FROM=ERPAIO <onboarding@resend.dev>

# ---------------------------------------------------------------------
# WHATSAPP — Twilio (Opsiyonel)
# ---------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=

# ---------------------------------------------------------------------
# OBSERVABILITY — Sentry (Önerilen)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---------------------------------------------------------------------
# RATE LIMIT — Upstash Redis (Önerilen — yoksa in-memory fallback)
# ---------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------
# BILLING — Stripe (Opsiyonel — Stripe TR'de yok, sandbox + non-TR için)
# ---------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ---------------------------------------------------------------------
# BILLING — iyzico (TR-first, Stripe alternatif — Track JJJJJJJ)
# ---------------------------------------------------------------------
# https://merchant.iyzipay.com → API Yönetimi
# Sandbox URL: https://sandbox-api.iyzipay.com
# Production URL: https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_PRICE_PRO=
IYZICO_PRICE_ENTERPRISE=
# Webhook imza doğrulama secret'ı (iyzico panel → Bildirim/Webhook)
IYZICO_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# NOTIFICATIONS — operasyonel e-posta alıcıları (Opsiyonel)
# ---------------------------------------------------------------------
# Landing demo/iletişim formundan gelen lead'lerin gönderileceği satış
# kutusu/kutuları. Virgülle ayrılmış. Boşsa lead loglanır ama yollanmaz.
LEAD_NOTIFY_EMAIL=
# Günlük cleanup cron'unun son 24h cron başarısızlık özetini yollayacağı
# sysadmin adresi/adresleri. Virgülle ayrılmış. Boşsa no-op.
SYSADMIN_NOTIFY_EMAIL=

# ---------------------------------------------------------------------
# BUDGET — token kill-switch (Opsiyonel)
# ---------------------------------------------------------------------
# Tenant başına günlük token tavanı (anomali/abuse koruması).
# Ayarlanmazsa varsayılan 1.000.000 token/tenant/gün.
DAILY_TOKEN_CAP=

# ---------------------------------------------------------------------
# ANALYTICS — PostHog (Opsiyonel — boşsa track() no-op)
# ---------------------------------------------------------------------
# NEXT_PUBLIC_* build-time inline edilir; non-prefixed eşdeğerleri runtime'da
# okunur (Vercel'de "Sensitive" işaretliyse build'e gelmez → non-prefixed kullan).
NEXT_PUBLIC_ANALYTICS_ENABLED=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Runtime fallback'ler (NEXT_PUBLIC_* yoksa):
ANALYTICS_ENABLED=
POSTHOG_KEY=
POSTHOG_HOST=

# ---------------------------------------------------------------------
# MISC
# ---------------------------------------------------------------------
# Log seviyesi — production: info, dev: debug
LOG_LEVEL=info
# Maintenance mode (true/false) — sayfa kilidi
MAINTENANCE_MODE=false
# Demo ERP seed script hedef DB URL'i (sadece scripts/seed-demo-erp.ts, dev)
DEMO_ERP_URL=
