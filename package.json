    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.14.0",
    "mssql": "^12.5.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "otpauth": "^9.5.1",
