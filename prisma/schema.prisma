generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                   String            @id @default(cuid())
  name                 String
  slug                 String            @unique
  plan                 String            @default("starter")
  whatsappTo           String?
  whatsappEnabled      Boolean           @default(true)
  emailTo              String?
  emailEnabled         Boolean           @default(false)
  alertMinSeverity     String            @default("high")
  monthlyTokenBudget   Int               @default(2000000)
  monthlyTokensUsed    Int               @default(0)
  budgetResetAt        DateTime          @default(now())
  trialEndsAt          DateTime?
  stripeCustomerId     String?           @unique
  stripeSubscriptionId String?           @unique
  subscriptionStatus   String?
  brandingLogoUrl      String?
  brandingPrimary      String?
  brandingSenderName   String?
  createdAt            DateTime          @default(now())
  users                User[]
  connections          ErpConnection[]
  chatSessions         ChatSession[]
  alerts               Alert[]
  baselines            AnomalyBaseline[]
  queryCache           QueryCache[]
  consentLogs          ConsentLog[]
  activityLogs         ActivityLog[]
  invitations          Invitation[]
  scheduledReports     ScheduledReport[]
  watchlists           Watchlist[]
  integrations         TenantIntegration[]
  ipAllowlist          TenantIpAllowlist[]
  tableEmbeddings      TableEmbedding[]
  npsResponses         NpsResponse[]
  customMetrics        CustomMetric[]
  schemaAnnotations    SchemaAnnotation[]
}

model User {
  id               String             @id @default(cuid())
  tenantId         String
  email            String             @unique
  emailVerifiedAt  DateTime?
  passwordHash     String
  name             String?
  avatarBase64     String?            @db.Text
  role             String             @default("viewer")
  isSysAdmin       Boolean            @default(false)
  totpSecretEnc    String?
  totpEnabled      Boolean            @default(false)
  failedLoginCount Int                @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime           @default(now())
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions             ChatSession[]
  apiTokens            ApiToken[]
  pushTokens           PushToken[]
  recoveryCodes        MfaRecoveryCode[]
  consentLogs          ConsentLog[]
  activityLogs         ActivityLog[]
  emailVerifyTokens    EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  scheduledReports     ScheduledReport[]
  watchlists           Watchlist[]
}

model MfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Account activity audit log — hassas mutasyonlar (şifre, profil, MFA,
/// oturum, takım) için append-only kayıt. KVKK md. 13 + GDPR Art. 30 kapsamında
/// işleme faaliyet kaydı. User silinse bile satır korunur (SetNull).
model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  tenantId   String?
  email      String? // user silindikten sonra audit için
  action     String // örn. "password.change", "profile.update", "mfa.enable"
  target     String? // ek hedef (e.g. session id, user id)
  metadata   Json? // değişen alanların özeti (PII'siz)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([action, createdAt])
}

/// KVKK / GDPR consent audit log.
/// Tüm onay/red ve geri alma işlemleri burada tutulur. Kullanıcı silinse bile
/// kayıt korunur (User foreign key SetNull) — md. 7 silinme hakkı + denetim
/// dengesi için retention 2+ yıl.
model ConsentLog {
  id           String   @id @default(cuid())
  userId       String?
  tenantId     String?
  email        String? // user silindikten sonra audit için
  consentType  String // "kvkk_signup" | "kvkk_marketing" | "kvkk_cookies" | "terms" | "privacy"
  action       String // "granted" | "withdrawn"
  documentVer  String? // örn. "v1.2" — TOS/Privacy versiyon takip
  ipAddress    String?
  userAgent    String?
  context      String? // ek bilgi: route, app version, vb.
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([consentType, createdAt])
}

model ErpConnection {
  id          String       @id @default(cuid())
  tenantId    String
  erpType     String
  erpProfile  String?
  host        String
  port        Int          @default(1433)
  dbName      String
  username    String
  passwordEnc String
  status      String       @default("pending")
  lastSync    DateTime?
  createdAt   DateTime     @default(now())
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schemaCache      SchemaCache?
  scheduledReports ScheduledReport[]
  watchlists       Watchlist[]
  tableEmbeddings  TableEmbedding[]
  customMetrics    CustomMetric[]
}

model SchemaCache {
  id           String        @id @default(cuid())
  connectionId String        @unique
  schemaText   String
  tableCount   Int
  builtAt      DateTime      @default(now())
  connection   ErpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id         String        @id @default(cuid())
  tenantId   String
  userId     String
  title      String?
  notes      String?
  pinned     Boolean       @default(false)
  archivedAt DateTime?
  createdAt  DateTime      @default(now())
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@index([tenantId, userId, archivedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  sqlQuery  String?
  rowCount  Int?
  latencyMs Int?
  success   Boolean     @default(true)
  feedback  Int?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Alert {
  id          String   @id @default(cuid())
  tenantId    String
  type        String
  severity    String   @default("medium")
  title       String
  description String?
  module      String?
  evidence    Json?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AnomalyBaseline {
  id          String   @id @default(cuid())
  tenantId    String
  metricKey   String
  value       Float
  capturedAt  DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime
  metadata    Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, metricKey, capturedAt(sort: Desc)])
  @@index([tenantId, capturedAt])
}

model CronRun {
  id            String     @id @default(cuid())
  jobName       String
  startedAt     DateTime   @default(now())
  finishedAt    DateTime?
  status        CronStatus @default(RUNNING)
  tenantsTotal  Int        @default(0)
  tenantsOk     Int        @default(0)
  tenantsFail   Int        @default(0)
  alertsCreated Int        @default(0)
  errorMessage  String?
  metadata      Json?

  @@index([jobName, startedAt(sort: Desc)])
  @@index([status])
}

enum CronStatus {
  RUNNING
  SUCCESS
  PARTIAL_FAILURE
  FAILED
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  name       String?
  tokenHash  String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PushToken {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  token      String   @unique
  platform   String
  deviceName String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}

model Invitation {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       String    @default("viewer")
  invitedBy  String
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tokenHash])
}

model ScheduledReport {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  name         String
  question     String
  connectionId String
  schedule     String
  emailTo      String
  enabled      Boolean   @default(true)
  lastRunAt    DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection ErpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([connectionId])
  @@index([enabled, schedule])
}

model Watchlist {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  name         String
  question     String
  connectionId String
  thresholdOp  String
  thresholdVal Float
  emailTo      String?
  enabled      Boolean   @default(true)
  lastRunAt    DateTime?
  lastValue    Float?
  triggeredAt  DateTime?
  createdAt    DateTime  @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection ErpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([connectionId])
  @@index([enabled])
}

model TenantIntegration {
  id            String    @id @default(cuid())
  tenantId      String
  kind          String
  endpointEnc   String
  secretEnc     String?
  enabled       Boolean   @default(true)
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind])
  @@index([tenantId])
}

model TenantIpAllowlist {
  id        String   @id @default(cuid())
  tenantId  String
  cidr      String
  label     String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cidr])
}

model TableEmbedding {
  id           String   @id @default(cuid())
  tenantId     String
  connectionId String
  tableName    String
  columnName   String?
  text         String
  embeddingHex String
  createdAt    DateTime @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection ErpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, connectionId, tableName, columnName])
  @@index([tenantId, connectionId])
}

model EncryptionKey {
  id           String    @id @default(cuid())
  version      Int       @unique
  keyHashSha256 String
  rotatedAt    DateTime?
  createdAt    DateTime  @default(now())
}

model NpsResponse {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  score       Int
  comment     String?
  promptedAt  DateTime
  respondedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // userId SetNull — kullanıcı silinse de anket data'sı aggregated analysis için kalır

  @@index([tenantId, respondedAt])
}

model CustomMetric {
  id           String    @id @default(cuid())
  tenantId     String
  connectionId String
  key          String
  label        String
  description  String?
  schedule     String    @default("hourly")
  algorithm    String    @default("zscore")
  direction    String    @default("both")
  configJson   Json?
  sql          String
  enabled      Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection ErpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, enabled])
  @@index([connectionId])
}

model SchemaAnnotation {
  id          String   @id @default(cuid())
  tenantId    String
  tableName   String
  columnName  String?
  description String?
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tableName, columnName])
  @@index([tenantId])
}

model QueryCache {
  id           String   @id @default(cuid())
  tenantId     String
  questionHash String
  question     String
  sqlQuery     String
  successCount Int      @default(0)
  failCount    Int      @default(0)
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, questionHash])
  @@index([tenantId, lastUsedAt(sort: Desc)])
}
