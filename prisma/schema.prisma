generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                   String            @id @default(cuid())
  name                 String
  slug                 String            @unique
  plan                 String            @default("starter")
  whatsappTo           String?
  whatsappEnabled      Boolean           @default(true)
  emailTo              String?
  emailEnabled         Boolean           @default(false)
  alertMinSeverity     String            @default("high")
  monthlyTokenBudget   Int               @default(2000000)
  monthlyTokensUsed    Int               @default(0)
  budgetResetAt        DateTime          @default(now())
  trialEndsAt          DateTime?
  stripeCustomerId     String?           @unique
  stripeSubscriptionId String?           @unique
  subscriptionStatus   String?
  createdAt            DateTime          @default(now())
  users                User[]
  connections          ErpConnection[]
  chatSessions         ChatSession[]
  alerts               Alert[]
  baselines            AnomalyBaseline[]
  queryCache           QueryCache[]
}

model User {
  id            String        @id @default(cuid())
  tenantId      String
  email         String        @unique
  passwordHash  String
  name          String?
  role          String        @default("viewer")
  isSysAdmin    Boolean       @default(false)
  totpSecretEnc String?
  totpEnabled   Boolean       @default(false)
  createdAt     DateTime      @default(now())
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions      ChatSession[]
  apiTokens     ApiToken[]
  pushTokens    PushToken[]
}

model ErpConnection {
  id          String       @id @default(cuid())
  tenantId    String
  erpType     String
  erpProfile  String?
  host        String
  port        Int          @default(1433)
  dbName      String
  username    String
  passwordEnc String
  status      String       @default("pending")
  lastSync    DateTime?
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schemaCache SchemaCache?
}

model SchemaCache {
  id           String        @id @default(cuid())
  connectionId String        @unique
  schemaText   String
  tableCount   Int
  builtAt      DateTime      @default(now())
  connection   ErpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(cuid())
  tenantId  String
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  sqlQuery  String?
  rowCount  Int?
  latencyMs Int?
  success   Boolean     @default(true)
  feedback  Int?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Alert {
  id          String   @id @default(cuid())
  tenantId    String
  type        String
  severity    String   @default("medium")
  title       String
  description String?
  module      String?
  evidence    Json?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AnomalyBaseline {
  id          String   @id @default(cuid())
  tenantId    String
  metricKey   String
  value       Float
  capturedAt  DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime
  metadata    Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, metricKey, capturedAt(sort: Desc)])
  @@index([tenantId, capturedAt])
}

model CronRun {
  id            String     @id @default(cuid())
  jobName       String
  startedAt     DateTime   @default(now())
  finishedAt    DateTime?
  status        CronStatus @default(RUNNING)
  tenantsTotal  Int        @default(0)
  tenantsOk     Int        @default(0)
  tenantsFail   Int        @default(0)
  alertsCreated Int        @default(0)
  errorMessage  String?
  metadata      Json?

  @@index([jobName, startedAt(sort: Desc)])
  @@index([status])
}

enum CronStatus {
  RUNNING
  SUCCESS
  PARTIAL_FAILURE
  FAILED
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  name       String?
  tokenHash  String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PushToken {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  token      String   @unique
  platform   String
  deviceName String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
}

model Invitation {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       String    @default("viewer")
  invitedBy  String
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([tenantId, email])
  @@index([tokenHash])
}

model ScheduledReport {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  name         String
  question     String
  connectionId String
  schedule     String
  emailTo      String
  enabled      Boolean   @default(true)
  lastRunAt    DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())

  @@index([tenantId])
  @@index([enabled, schedule])
}

model Watchlist {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  name         String
  question     String
  connectionId String
  thresholdOp  String
  thresholdVal Float
  emailTo      String?
  enabled      Boolean   @default(true)
  lastRunAt    DateTime?
  lastValue    Float?
  triggeredAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId])
  @@index([enabled])
}

model TenantIpAllowlist {
  id        String   @id @default(cuid())
  tenantId  String
  cidr      String
  label     String?
  createdAt DateTime @default(now())

  @@unique([tenantId, cidr])
}

model SchemaAnnotation {
  id          String   @id @default(cuid())
  tenantId    String
  tableName   String
  columnName  String?
  description String?
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, tableName, columnName])
  @@index([tenantId])
}

model QueryCache {
  id           String   @id @default(cuid())
  tenantId     String
  questionHash String
  question     String
  sqlQuery     String
  successCount Int      @default(0)
  failCount    Int      @default(0)
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, questionHash])
  @@index([tenantId, lastUsedAt(sort: Desc)])
}
